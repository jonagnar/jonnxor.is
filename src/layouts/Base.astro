---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";

interface Props {
  title: string;
  page?: string;
  dragonfly?: string;
  theme?: string;
}
const { title, page = "", dragonfly, theme = "rune" } = Astro.props;
---

<!doctype html>
<html lang={Astro.currentLocale ?? "is"} data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {/* Pre-paint theme: apply persisted choice before first render to avoid a flash */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("jx-theme");
          if (t) document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    {/* Favicon / app icons — raster set generated from favicon.svg by scripts/generate-icons.mjs */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#07060c" />
    <link rel="stylesheet" href="/assets/fonts.css" />
    <link rel="stylesheet" href="/assets/tokens.css" />
    <link rel="stylesheet" href="/assets/site.css" />
    <slot name="head" />
  </head>
  <body data-page={page} data-dragonfly={dragonfly}>
    {/* Nav.astro server-renders the adaptive nav + mobile dock; site.js wires behavior + appends the search modal */}
    <Nav page={page} />
    <slot />
    <Footer />
    <script is:inline src="/assets/site.js"></script>
    {/* page-specific scripts run here — AFTER site.js so window.JX is ready */}
    <slot name="end" />
  </body>
</html>
