---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const ACCENT = { "Engineering": "tq", "Games × Code": "gold" };
const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["All", ...new Set(posts.map((p) => p.data.category))];
const fmtDate = (d) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
const isoDate = (d) => d.toISOString().slice(0, 10);
---

<Base title="Blog — JonnXor" page="blog">
  <main>
    <section class="page-head" data-screen-label="Blog head">
      <div class="container">
        <p class="kicker">Blog</p>
        <h1>The Codex</h1>
        <p class="lede">Long-form writing on code, myth, games, and the spaces between.</p>
      </div>
    </section>

    <div class="container">
      <div class="rune-divider" aria-hidden="true"><span class="runes"></span></div>

      <div class="blog-filters" data-screen-label="Blog filters">
        {categories.map((c, i) => (
          <span class:list={["chip", { tq: i === 0 }]}>{c}</span>
        ))}
      </div>

      <section class="post-list" data-screen-label="Post list">
        {posts.map((post) => (
          <a class="card lift post-card reveal" href={`/blog/${post.id}`}>
            <div class="top">
              <time datetime={isoDate(post.data.date)}>{fmtDate(post.data.date)}</time>
              <span class:list={["chip", ACCENT[post.data.category]]}>{post.data.category}</span>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.excerpt}</p>
            <span class="read">Read · {post.data.readTime} →</span>
          </a>
        ))}
      </section>
    </div>
  </main>

  <style is:global>
    .post-list { max-width: 820px; margin: 0 auto; display: flex; flex-direction: column; gap: 18px; }
    .post-card { padding: 26px 28px; color: var(--ink); display: block; }
    .post-card:hover { text-decoration: none; }
    .post-card .top { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; flex-wrap: wrap; }
    .post-card time { font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-faint); }
    .post-card h2 { font-size: 20px; margin: 0 0 8px; }
    .post-card p { font-size: 14.5px; color: var(--ink-soft); margin: 0; }
    .post-card .read { font-family: var(--font-display); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--gold-ink); display: inline-block; margin-top: 12px; }
    .blog-filters { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-bottom: 34px; }
    .blog-filters .chip { cursor: pointer; }
  </style>
</Base>
