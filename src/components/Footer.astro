---
// Site footer — server-rendered; strings via the i18n dictionary, links locale-aware.
import { useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? "is";
const t = useTranslations(locale);
const localeHref = (path: string) => getRelativeLocaleUrl(locale, path);
---
<footer class="site-footer">
  <div class="foot-inner">
    <div class="foot-brand">
      <a class="nav-logo" href={localeHref("/")}>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M21 11 L8 5 L3 1 L7 8 L4 9 L8 17 L14 14 L12 11 Z"/></svg>
        <span>JONN<span class="xor">XOR</span></span>
      </a>
      <p class="foot-tag">{t("foot.tag")}</p>
      <p class="foot-note">{t("foot.note")}</p>
    </div>
    <div class="foot-sign" aria-hidden="true">
      <svg viewBox="0 0 240 130" fill="none">
        <g class="lines" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 12 L80 36 L92 44 L106 54 M20 86 L82 72 L94 66 L106 54 M106 54 L136 66 L170 80 L192 74"/>
        </g>
        <g class="stars">
          <circle cx="16" cy="12" r="2.6"/><circle cx="80" cy="36" r="2"/><circle cx="92" cy="44" r="1.7"/>
          <circle cx="106" cy="54" r="2.2"/><circle cx="20" cy="86" r="2.4"/><circle cx="94" cy="66" r="1.7"/>
          <circle cx="136" cy="66" r="1.8"/><circle cx="170" cy="80" r="2"/><circle cx="192" cy="74" r="1.7"/>
          <circle class="alde" cx="82" cy="72" r="3.4"/>
        </g>
        <g class="stars" opacity=".7">
          <circle cx="172" cy="22" r="1.2"/><circle cx="178" cy="17" r="1"/><circle cx="184" cy="24" r="1.2"/>
          <circle cx="176" cy="28" r="1"/><circle cx="183" cy="31" r="1"/><circle cx="189" cy="19" r="1"/>
        </g>
        <text class="caption" x="120" y="122" text-anchor="middle">{t("foot.caption")}</text>
      </svg>
    </div>
    <div class="foot-contact">
      <h3 class="foot-hd">{t("foot.contactHd")}</h3>
      <div class="foot-row"><span class="k">{t("foot.k.raven")}</span><a href="mailto:jon@jonnxor.is">jon@jonnxor.is</a></div>
      <div class="foot-row"><span class="k">{t("foot.k.github")}</span><a href="https://github.com" target="_blank" rel="noopener">github.com/jonnxor</a></div>
      <div class="foot-row"><span class="k">{t("foot.k.linkedin")}</span><a href="https://linkedin.com" target="_blank" rel="noopener">in/jonnxor</a></div>
      <div class="foot-row"><span class="k">{t("foot.k.hall")}</span><span>{t("foot.location")}</span></div>
      <div class="foot-row"><span class="k">{t("foot.k.status")}</span><span class="chip tq">{t("foot.status")}</span></div>
    </div>
  </div>
  <div class="foot-bottom">
    <span>{t("foot.copyright")}</span>
    <div class="foot-links">
      <a href={localeHref("/cv")}>{t("foot.link.cv")}</a>
      <a href={localeHref("/wallpapers")}>{t("foot.link.wallpapers")}</a>
      <a href={localeHref("/404")}>{t("foot.link.dragons")}</a>
    </div>
  </div>
</footer>
